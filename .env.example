# Copy to .env and fill in real values. Never commit .env.
# If any key or password was ever exposed, rotate it in the provider console and update here.

GEMINI_API_KEY=
DATABASE_URL=postgresql://user:password@host:5432/dbname

APP_NAME=Chat Bot API
APP_ENV=development
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO

CHROMA_PERSIST_DIR=./.chroma
CHROMA_COLLECTION_NAME=chatbot_knowledge_gemini

MODEL_NAME=gemini-2.0-flash
EMBEDDING_MODEL=gemini-embedding-001

TOP_K=4
CHUNK_SIZE=800
CHUNK_OVERLAP=120
CONFIDENCE_THRESHOLD=0.4

# Security limits (optional; defaults are safe for typical RAG use)
# MAX_UPLOAD_BYTES=26214400
# MAX_JSON_BODY_BYTES=524288
# MAX_CHAT_MESSAGE_CHARS=16000
# MAX_FEEDBACK_COMMENT_CHARS=4000

# Rate limits (slowapi; restart after change)
# RATE_LIMIT_CHAT_PER_IP=60/minute
# RATE_LIMIT_CHAT_PER_SESSION=30/minute
# RATE_LIMIT_INGEST_PER_IP=10/minute
